<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application>
        <!--
          AboutActivity is declared here so manifest merging adds it to every
          consuming app automatically. Theme/exported can be overridden per-app
          via a matching <activity> entry with tools:node="merge" if needed.
        -->
        <activity
            android:name=".ui.AboutActivity"
            android:exported="false"
            android:theme="@style/Theme.Rama.Base" />
    </application>

</manifest>
