<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
      Every app theme should extend this (directly or via its own
      Theme.<AppName> -> Theme.Rama.Base chain) and override the
      ramaXxx attrs below with its own palette.

      Example, in an app's themes.xml:

        <style name="Theme.Txori" parent="Theme.Rama.Base">
            <item name="ramaWindowBg">@color/txori_bg</item>
            <item name="ramaCardBackground">@color/txori_card</item>
            <item name="ramaAccentColor">@color/txori_accent</item>
        </style>
    -->
    <style name="Theme.Rama.Base" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="ramaWindowBg">@color/rama_default_window_bg</item>
        <item name="ramaCardBackground">@color/rama_default_card_bg</item>
        <item name="ramaDividerColor">@color/rama_default_divider</item>
        <item name="ramaTextColor">@color/rama_default_text</item>
        <item name="ramaTextColorSecondary">@color/rama_default_text_secondary</item>
        <item name="ramaAccentColor">@color/rama_default_accent</item>

        <item name="android:windowBackground">?attr/ramaWindowBg</item>
        <item name="colorAccent">?attr/ramaAccentColor</item>
        <item name="android:isLightTheme">false</item>
    </style>

</resources>
